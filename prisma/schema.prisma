generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BetStatus {
  PENDING
  CONFIRMED
  REJECTED
  SETTLED_WIN
  SETTLED_LOSS
  VOID
}

// Stage 1 of the Bet -> Bet + BetSelection migration (see README "What's not
// done yet" / parlay research). Purely additive: existing single-event bets
// keep working unchanged via the old sport/event/outcome/odds fields below,
// which are NOT removed yet.
enum BetType {
  SINGLE
  PARLAY
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_STAKE
  BET_PAYOUT
  ADJUSTMENT
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model Operator {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())

  players Player[]
}

model Player {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])

  name        String
  telegramId  String?  @unique
  phoneNumber String?
  createdAt   DateTime @default(now())

  creditLimit   Decimal @default(10000) @db.Decimal(18, 6)
  currentCredit Decimal @default(0) @db.Decimal(18, 6) // + player is up, - player owes

  wallet       Wallet?
  bets         Bet[]
  messages     Message[]
  transactions Transaction[]

  @@index([operatorId])
}

model Wallet {
  id       String @id @default(cuid())
  playerId String @unique
  player   Player @relation(fields: [playerId], references: [id])

  balance   Decimal  @default(0) @db.Decimal(18, 6) // USDC
  updatedAt DateTime @updatedAt
}

model Bet {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  // Transitional single-event fields — still the source of truth for every
  // existing bet today. Not removed in Stage 1; see README for the planned
  // backfill (Stage 2) before these are ever dropped.
  sport   String
  event   String
  outcome String
  odds    Decimal? @db.Decimal(6, 2)
  stake   Decimal  @db.Decimal(18, 6) // USDC

  // Stage 1 additions for parlay support. `type` defaults to SINGLE so every
  // existing row is valid without a backfill; `totalOdds` is nullable and
  // unused until something actually populates it for a PARLAY bet.
  type       BetType        @default(SINGLE)
  totalOdds  Decimal?       @db.Decimal(10, 2)
  selections BetSelection[]

  // Stage 4.4A idempotency key for Mini App text-bet confirm: the previewId
  // from a verified, short-lived signed preview token (see
  // lib/betPreview/previewToken.ts). Nullable — only confirm-created bets
  // set it; every other creation path (operator dashboard, WhatsApp-era
  // betService.ts) leaves it null. The unique constraint is what actually
  // prevents a double-submit/race from creating two Bets, not the
  // pre-insert lookup in the confirm route.
  previewId String? @unique

  status     BetStatus @default(PENDING)
  rawMessage String? // исходный текст от игрока

  oddsSnapshot OddsSnapshot?
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([playerId])
  @@index([status])
}

// New in Stage 1 — not yet populated or read by any application code. A
// future stage will backfill one BetSelection per existing single Bet, then
// switch API/UI consumers over, then (much later) drop Bet's own
// sport/event/outcome/odds fields. No BetSelection-level status yet — bet
// results are still tracked only on Bet.status for now.
model BetSelection {
  id    String @id @default(cuid())
  betId String
  bet   Bet    @relation(fields: [betId], references: [id], onDelete: Cascade)

  sport   String
  event   String
  outcome String
  odds    Decimal? @db.Decimal(6, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([betId])
}

model OddsSnapshot {
  id    String @id @default(cuid())
  betId String @unique
  bet   Bet    @relation(fields: [betId], references: [id])

  sourceOdds    Decimal? @db.Decimal(6, 2)
  submittedOdds Decimal  @db.Decimal(6, 2)
  matched       Boolean
  checkedAt     DateTime @default(now())
}

model Transaction {
  id       String  @id @default(cuid())
  playerId String
  player   Player  @relation(fields: [playerId], references: [id])
  betId    String?
  bet      Bet?    @relation(fields: [betId], references: [id])

  type         TransactionType
  amount       Decimal         @db.Decimal(18, 6)
  balanceAfter Decimal         @db.Decimal(18, 6)

  createdAt DateTime @default(now())

  @@index([playerId])
}

model Message {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  direction MessageDirection
  content   String
  betId     String?

  createdAt DateTime @default(now())

  @@index([playerId])
}
