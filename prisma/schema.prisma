generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BetStatus {
  PENDING
  CONFIRMED
  REJECTED
  SETTLED_WIN
  SETTLED_LOSS
  VOID
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_STAKE
  BET_PAYOUT
  ADJUSTMENT
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model Operator {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())

  players Player[]
}

model Player {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])

  name        String
  whatsappId  String   @unique
  createdAt   DateTime @default(now())

  wallet       Wallet?
  bets         Bet[]
  messages     Message[]
  transactions Transaction[]

  @@index([operatorId])
}

model Wallet {
  id        String   @id @default(cuid())
  playerId  String   @unique
  player    Player   @relation(fields: [playerId], references: [id])

  balance   Decimal  @default(0) @db.Decimal(18, 6) // USDC
  updatedAt DateTime @updatedAt
}

model Bet {
  id         String    @id @default(cuid())
  playerId   String
  player     Player    @relation(fields: [playerId], references: [id])

  sport      String
  event      String
  outcome    String
  odds       Decimal?  @db.Decimal(6, 2)
  stake      Decimal   @db.Decimal(18, 6) // USDC

  status     BetStatus @default(PENDING)
  rawMessage String?   // исходный текст от игрока

  oddsSnapshot OddsSnapshot?
  transactions Transaction[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([playerId])
  @@index([status])
}

model OddsSnapshot {
  id           String   @id @default(cuid())
  betId        String   @unique
  bet          Bet      @relation(fields: [betId], references: [id])

  sourceOdds   Decimal? @db.Decimal(6, 2)
  submittedOdds Decimal @db.Decimal(6, 2)
  matched      Boolean
  checkedAt    DateTime @default(now())
}

model Transaction {
  id        String          @id @default(cuid())
  playerId  String
  player    Player          @relation(fields: [playerId], references: [id])
  betId     String?
  bet       Bet?            @relation(fields: [betId], references: [id])

  type      TransactionType
  amount    Decimal         @db.Decimal(18, 6)
  balanceAfter Decimal      @db.Decimal(18, 6)

  createdAt DateTime        @default(now())

  @@index([playerId])
}

model Message {
  id         String            @id @default(cuid())
  playerId   String
  player     Player            @relation(fields: [playerId], references: [id])

  direction  MessageDirection
  content    String
  betId      String?

  createdAt  DateTime          @default(now())

  @@index([playerId])
}
