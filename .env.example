# Neon Postgres connection string (pooled endpoint recommended for serverless/Vercel).
# Get it from: Neon Console → Project → Connection Details
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"

# AI provider used by lib/ai/betParser.ts to parse incoming bet messages.
# "ollama" (default) — local Ollama chat API, no key required.
# "claude" — Anthropic API, requires ANTHROPIC_API_KEY below.
AI_PROVIDER="ollama"

# Local Ollama server. Only used when AI_PROVIDER="ollama".
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# Anthropic API key. Only required when AI_PROVIDER="claude".
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# The Odds API key for live odds verification (lib/odds/oddsVerifier.ts).
# Get it from: https://the-odds-api.com/ → Account
ODDS_API_KEY="your-odds-api-key"

# Bearer token operators must send to call /api/bets/* endpoints
# (Authorization: Bearer <value>). Any random string works locally —
# it's not used for cryptographic signing, just shared-secret comparison.
OPERATOR_SECRET="replace-with-a-random-string"
